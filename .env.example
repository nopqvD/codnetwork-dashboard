# ─────────────────────────────────────────────────────────────────────────────
# CODNETWORK Dashboard — Environment Variables
# Copy this file to .env for local development
# On Railway: set these in the Variables tab (never commit .env)
# ─────────────────────────────────────────────────────────────────────────────

# Server port — Railway sets this automatically, leave blank locally
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database URL (REQUIRED for email/password authentication)
# On Railway: Add a PostgreSQL service and use its connection string
# Example: postgresql://user:password@host:port/dbname
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# After setting DATABASE_URL, run: node migrate.js
# This creates the users, sessions, notifications, and other tables.
#
# Webhook URL to configure in CODNETWORK:
#   https://your-domain.railway.app/webhook?token=YOUR_API_TOKEN
# ─────────────────────────────────────────────────────────────────────────────
